# Server
PORT=3000
API_KEY=your-api-key-here

# Integration mode: "demo" returns simulated responses, "live" makes real HTTP calls
INTEGRATION_MODE=demo

# OpenAI (optional — enables AI intent classification)
OPENAI_API_KEY=

# HubSpot
HUBSPOT_API_KEY=
HUBSPOT_BASE_URL=https://api.hubapi.com

# Wastedge
WASTEDGE_BASE_URL=https://api.wastedge.example.com
WASTEDGE_API_KEY=

# ServiceM8
SERVICEM8_BASE_URL=https://api.servicem8.com
SERVICEM8_API_KEY=

# Microsoft 365
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=

# Logging
LOG_LEVEL=info
